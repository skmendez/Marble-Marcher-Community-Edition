target/
target-*/

# wasm-bindgen output (generated by `wasm-bindgen` from the compiled
# wasm32-unknown-unknown binary — see rust/README.md's web build section).
# index.html and net.js (multiplayer milestone 2's hand-written PeerJS
# wrapper, loaded by index.html before the generated bundle) are
# hand-written and stay tracked -- the negation must come after the
# blanket `web/*.js` rule, since gitignore evaluates patterns in order.
web/*.js
web/*.wasm
!web/net.js
